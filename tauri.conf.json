{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chaemera",
  "version": "0.37.0-beta.2",
  "identifier": "io.chaemera.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "./dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chaemera",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true
      }
    ]
  }
}
