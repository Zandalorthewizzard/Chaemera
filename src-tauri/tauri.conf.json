{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chaemera",
  "version": "0.37.0-beta.2",
  "identifier": "io.chaemera.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chaemera",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "resources": [
      "../worker/dyad_logs.js",
      "../worker/dyad-component-selector-client.js",
      "../worker/dyad-screenshot-client.js",
      "../worker/dyad-shim.js",
      "../worker/dyad-sw-register.js",
      "../worker/dyad-sw.js",
      "../worker/dyad-visual-editor-client.js",
      "../worker/proxy_server.js",
      "../worker/proxy_server_cli.js",
      "../worker/tsc_worker_runner.js",
      "../.vite/build/tsc_worker.js",
      "../node_modules/html-to-image/dist/html-to-image.js",
      "../node_modules/stacktrace-js/dist/stacktrace.min.js"
    ]
  }
}
