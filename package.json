{
  "name": "chaemera",
  "version": "0.37.0-beta.3",
  "description": "Free, local, open-source AI app builder",
  "keywords": [],
  "license": "Apache-2.0",
  "author": {
    "name": "Chaemera contributors"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zandalorthewizzard/Chaemera.git"
  },
  "scripts": {
    "clean": "rimraf out scaffold/node_modules",
    "dev:renderer": "npx vite --config vite.renderer.config.mts --host 127.0.0.1 --port 5173",
    "start": "npm run start:tauri",
    "start:tauri": "node scripts/run-tauri-cli.js dev",
    "dev:engine": "cross-env DYAD_ENGINE_URL=http://localhost:8080/v1 npm run start:tauri",
    "staging:engine": "cross-env DYAD_ENGINE_URL=https://staging---dyad-llm-engine-kq7pivehnq-uc.a.run.app/v1 npm run start:tauri",
    "package": "npm run package:tauri",
    "package:tauri": "node scripts/run-tauri-cli.js build",
    "build:renderer": "npx vite build --config vite.renderer.config.mts --outDir dist",
    "build:chat-worker": "npx vite build --config vite.chat-worker.config.mts",
    "build:tsc-worker": "npx vite build --config vite.worker.config.mts",
    "build:workers": "npm run build:chat-worker && npm run build:tsc-worker",
    "audit:tauri-cutover": "node scripts/audit-tauri-cutover.js",
    "audit:electron-legacy": "node scripts/audit-electron-legacy-surface.js",
    "ts": "npm run ts:main && npm run ts:workers",
    "ts:main": "npx tsgo -p tsconfig.app.json --noEmit --incremental",
    "ts:workers": "npx tsc -p workers/tsc/tsconfig.json --noEmit --incremental",
    "lint": "npx oxlint --fix",
    "lint:fix": "npx oxlint --fix --fix-suggestions --fix-dangerously",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "fmt:check": "npx oxfmt --check",
    "fmt": "npx oxfmt",
    "presubmit": "npm run fmt:check && npm run lint",
    "test": "cross-env NODE_OPTIONS=--no-deprecation VITE_CJS_IGNORE_WARNING=true vitest run",
    "test:watch": "cross-env NODE_OPTIONS=--no-deprecation VITE_CJS_IGNORE_WARNING=true vitest",
    "test:ui": "cross-env NODE_OPTIONS=--no-deprecation VITE_CJS_IGNORE_WARNING=true vitest --ui",
    "extract-codebase": "ts-node scripts/extract-codebase.ts",
    "init-precommit": "husky",
    "build": "npm run pre:e2e",
    "check:tauri": "cargo check --manifest-path src-tauri/Cargo.toml",
    "build:tauri-runtime-app": "node scripts/build-tauri-runtime-app.js",
    "build:tauri-regression": "npx vite build --config vite.renderer.config.mts --outDir .tauri-smoke-dist",
    "build:tauri-smoke": "npm run build:tauri-regression",
    "serve:tauri-regression": "npx vite preview --config vite.renderer.config.mts --host 127.0.0.1 --port 4173 --outDir .tauri-smoke-dist",
    "serve:tauri-smoke": "npm run serve:tauri-regression",
    "pre:e2e:tauri-regression": "npm run build:tauri-regression",
    "pre:e2e:tauri-runtime": "npm run build:workers && npm run build:tauri-runtime-app",
    "pre:e2e:tauri-smoke": "npm run pre:e2e:tauri-regression",
    "pre:e2e:full": "node scripts/prep-full-desktop-e2e.js",
    "pre:e2e:ci": "npm run pre:e2e:full",
    "pre:e2e": "npm run pre:e2e:tauri-regression",
    "e2e": "playwright test --project=tauri-regression",
    "e2e:full": "node scripts/run-full-desktop-e2e.js",
    "e2e:ci": "npm run e2e:full",
    "e2e:tauri-regression": "playwright test --project=tauri-regression",
    "e2e:tauri-runtime": "npm --prefix testing/tauri-webdriver test",
    "e2e:tauri-smoke": "npm run e2e:tauri-regression",
    "e2e:p3": "PLAYWRIGHT_RETRIES=1 PLAYWRIGHT_PARALLELISM=3 playwright test",
    "e2e:shard": "playwright test --shard",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
